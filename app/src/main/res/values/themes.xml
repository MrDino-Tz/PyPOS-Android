<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Font Family -->
    <style name="TextAppearance.PyPOS.Poppins" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/poppins</item>
    </style>

    <!-- Base application theme -->
    <style name="Base.Theme.PyPOS" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorTertiary">@color/info</item>
        <item name="colorError">@color/danger</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="Theme.PyPOS" parent="Base.Theme.PyPOS" />

    <!-- Button Styles -->
    <style name="Widget.PyPOS.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.PyPOS.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/gray_100</item>
        <item name="android:textColor">@color/gray_700</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.PyPOS.Button.Success" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/success</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.PyPOS.Button.Danger" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.PyPOS.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.PyPOS.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.PyPOS.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="TextAppearance.PyPOS.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <!-- TextInput Style -->
    <style name="Widget.PyPOS.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="boxStrokeColor">@color/gray_300</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/gray_500</item>
    </style>

    <!-- TextInputEditText Style -->
    <style name="Widget.PyPOS.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/gray_400</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.PyPOS.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.PyPOS.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">6dp</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="TextAppearance.PyPOS.BottomNav" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <!-- Rounded Corner Style for ImageView -->
    <style name="RoundedCorner" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>
