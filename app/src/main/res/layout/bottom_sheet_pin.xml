<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Subtle drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_round_gray" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Enter PIN"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="32dp">

        <!-- 4 dots mimicking the requested design -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/pinDot1"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_pin_circle_focused_large" />

            <View
                android:id="@+id/pinDot2"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_pin_circle_empty_large" />

            <View
                android:id="@+id/pinDot3"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_pin_circle_empty_large" />

            <View
                android:id="@+id/pinDot4"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_pin_circle_empty_large" />
        </LinearLayout>

        <!-- EditText with phone dialer input -->
        <EditText
            android:id="@+id/etHiddenPin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@null"
            android:cursorVisible="false"
            android:gravity="center"
            android:inputType="phone"
            android:maxLength="4"
            android:textColor="@android:color/transparent"
            android:textSize="1sp" />
    </FrameLayout>
    
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/primary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>